<% cache @product do %>
  <h1><%= @product.name %></h1>
  <%= image_tag @product.featured_image if @product.featured_image.attached? %>
  <%= @product.description %>
<% end %>

<%= render "inventory", product: @product %>

<%= link_to "Back", products_path %>
<%= link_to "Edit", edit_product_path(@product) if authenticated? %>
<%= button_to "Delete", @product, method: :delete, data: { turbo_confirm: "Are you sure?" } if authenticated? %>
